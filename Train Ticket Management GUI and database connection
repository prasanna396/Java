    void connectToOracle() {
        try {

        Class.forName("oracle.jdbc.driver.OracleDriver");
        String url = "jdbc:oracle:thin:@172.16.16.50:1521:ORACLE21C";
        String username = "C##24BCS055";
        String pwd = "C##24BCS055";
        con = DriverManager.getConnection(url, username, pwd);
             System.out.println("Connected to Oracle Database successfully!");
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Database Connection Failed: " + e.getMessage(), "Connection Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    public void actionPerformed(ActionEvent e) {
        if (e.getSource() == submitBtn) {

            String custName = custNameField.getText();
            String mobile = mobileField.getText();
            String email = emailField.getText();
            String trainNo = trainNoField.getText();
            String source = sourceField.getText();
            String destination = destField.getText();
            String date = dateField.getText();

            int noOfTickets = 0;
            double amountPerPerson = 0.0;
            double billAmount = 0.0;

            try {
                noOfTickets = Integer.parseInt(ticketsField.getText());
                amountPerPerson = Double.parseDouble(amountPerPersonField.getText());

                billAmount = noOfTickets * amountPerPerson;
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(this,
                    "Please enter valid numeric values for 'No. of Tickets' and 'Amount per Person'.",
                    "Input Error", JOptionPane.ERROR_MESSAGE);
                return;
             }

            try {

                String sql = "INSERT INTO TRAINS ("
                        + "CUST_NAME,CUST_NUM,CUST_EMAIL,TRAIN_NUM,SOURCE,DESTINATION,NO_OF_TICK,AMT_PER_PER,T_DATE,BILL) "
                        + "VALUES(?, ?, ?, ?, ?, ?, ?, ?, ?, ?)";

                pst = con.prepareStatement(sql);

                pst.setString(1, custName);
                pst.setString(2, mobile);
                pst.setString(3, email);
                pst.setString(4, trainNo);
                pst.setString(5, source);
                pst.setString(6, destination);
                pst.setInt(7, noOfTickets);
                pst.setDouble(8, amountPerPerson);
                pst.setString(9, date);
                pst.setDouble(10, billAmount);

                pst.executeUpdate();

                String billMessage = String.format(
                    "--- BOOKING SUCCESSFUL ---\n\n" +
                    "Customer: %s\n" +
                    "Mobile: %s\n" +
                    "Train No: %s (%s to %s)\n" +
                    "Date of Journey: %s\n\n" +
                    "Tickets Booked: %d\n" +
                    "Cost per Ticket: ₹ %.2f\n\n" +
                    "TOTAL BILL AMOUNT: ₹ %.2f",
                    custName, mobile, trainNo, source, destination, date,
                    noOfTickets, amountPerPerson, billAmount
                );

                JOptionPane.showMessageDialog(this, billMessage, "Ticket Confirmation & Bill", JOptionPane.INFORMATION_MESSAGE);

                resetFields();

            } catch (SQLException ex) {
                JOptionPane.showMessageDialog(this, "Database Error: " + ex.getMessage(), "SQL Error", JOptionPane.ERROR_MESSAGE);
            }
        } else if (e.getSource() == resetBtn) {
            resetFields();
        }
    }

    private void resetFields() {
        custNameField.setText("");
        mobileField.setText("");
        emailField.setText("");
        trainNoField.setText("");
        sourceField.setText("");
        destField.setText("");
        ticketsField.setText("");
        amountPerPersonField.setText("");
        dateField.setText("");
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> {
            new TrainTicketManagement();
        });
}
}
