        title.setBounds(120, 20, 300, 30);
        add(title);

        JLabel custNameLbl = new JLabel("Customer Name:");
        custNameLbl.setBounds(50, 80, 150, 25);
        add(custNameLbl);
        custNameField = new JTextField();
        custNameField.setBounds(220, 80, 200, 25);
        add(custNameField);

        JLabel mobileLbl = new JLabel("Mobile Number:");
        mobileLbl.setBounds(50, 120, 150, 25);
        add(mobileLbl);
        mobileField = new JTextField();
        mobileField.setBounds(220, 120, 200, 25);
        add(mobileField);

        JLabel emailLbl = new JLabel("Email:");
        emailLbl.setBounds(50, 160, 150, 25);
        add(emailLbl);
        emailField = new JTextField();
        emailField.setBounds(220, 160, 200, 25);
        add(emailField);

        JLabel trainNoLbl = new JLabel("Train No:");
        trainNoLbl.setBounds(50, 200, 150, 25);
        add(trainNoLbl);
        trainNoField = new JTextField();
        trainNoField.setBounds(220, 200, 200, 25);
        add(trainNoField);

        JLabel sourceLbl = new JLabel("Source:");
        sourceLbl.setBounds(50, 240, 150, 25);
        add(sourceLbl);
        sourceField = new JTextField();
        sourceField.setBounds(220, 240, 200, 25);
        add(sourceField);

        JLabel destLbl = new JLabel("Destination:");
        destLbl.setBounds(50, 280, 150, 25);
        add(destLbl);
        destField = new JTextField();
        destField.setBounds(220, 280, 200, 25);
        add(destField);

        JLabel dateLbl = new JLabel("Date (DD/MM/YYYY):");
        dateLbl.setBounds(50, 320, 150, 25);
        add(dateLbl);
        dateField = new JTextField();
        dateField.setBounds(220, 320, 200, 25);
        add(dateField);

        JLabel ticketsLbl = new JLabel("No. of Tickets:");
        ticketsLbl.setBounds(50, 360, 150, 25);
        add(ticketsLbl);
        ticketsField = new JTextField();
        ticketsField.setBounds(220, 360, 200, 25);
        add(ticketsField);

        JLabel amountLbl = new JLabel("Amount per Person (₹):");
        amountLbl.setBounds(50, 400, 150, 25);
