import java.util.Random;
public class MultiThread {
    public static void main(String[] args) {
        System.out.println("Starting 3 Threads...");

        // Create and start all 3 threads
        Thread randomThread = new Thread(new RandomGenerator());
        Thread squareThread = new Thread(new SquareCalculator());
        Thread cubeThread = new Thread(new CubeCalculator());

        randomThread.start();
        squareThread.start();
        cubeThread.start();
    }
}

// Thread 1: Generates random numbers every second
class RandomGenerator implements Runnable {
    private Random random = new Random();

    @Override
    public void run() {
        try {
            for(int i=1;i<=10;i++){
                int num = random.nextInt(10) + 1; // 1 to 10
                System.out.println("Random Number: " + num);

                // Create new threads for square and cube with the current number
                new Thread(new SquareCalculator(num)).start();
                new Thread(new CubeCalculator(num)).start();

                Thread.sleep(1000); // 1 second delay
            }
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
    }
}

// Thread 2: Calculates square
class SquareCalculator implements Runnable {
    private int number;

    // Constructor for when called from main (no number)
    public SquareCalculator() {
        this.number = 0;
    }

    // Constructor for when called with a specific number
    public SquareCalculator(int num) {
        this.number = num;
    }

    @Override
    public void run() {
        if (number != 0) {
            int square = number * number;
            System.out.println("Square of " + number + " = " + square);
        }
    }
}

// Thread 3: Calculates cube
class CubeCalculator implements Runnable {
    private int number;

    // Constructor for when called from main (no number)
    public CubeCalculator() {
        this.number = 0;
    }

    // Constructor for when called with a specific number
    public CubeCalculator(int num) {
        this.number = num;
    }


    public void run() {
        if (number != 0) {
            int cube = number * number * number;
            System.out.println("Cube of " + number + " = " + cube);
        }
    }
}
